# Big Tech Best Practices - Feature Flow (OpportunitySpec Start)
# Combines 10 company methodologies
# Layout: ELK

direction: down

title: {
  label: Big Tech Feature Flow (10 Companies)
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# Phase labels
discovery: {
  label: "1. DISCOVERY"
  shape: text
  style.font-size: 16
  style.bold: true
  style.fill: transparent
}

vision: {
  label: "2. VISION"
  shape: text
  style.font-size: 16
  style.bold: true
  style.fill: transparent
}

requirements: {
  label: "3. REQUIREMENTS"
  shape: text
  style.font-size: 16
  style.bold: true
  style.fill: transparent
}

experience: {
  label: "4. EXPERIENCE"
  shape: text
  style.font-size: 16
  style.bold: true
  style.fill: transparent
}

technical: {
  label: "5. TECHNICAL"
  shape: text
  style.font-size: 16
  style.bold: true
  style.fill: transparent
}

# Discovery Phase (Patton + Cagan + Google)
opportunity-spec: {
  label: OpportunitySpec + OKRs\n(Patton + Cagan + Google)
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
}

# Vision Phase (Amazon)
press: {
  label: Press Release\n(Amazon)
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
}

faq: {
  label: FAQ + Dev FAQ\n(Amazon + Stripe)
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
}

# Requirements Phase (Google + Stripe)
prd: {
  label: PRD + API Contracts\n(Google + Stripe)
  shape: rectangle
  style.fill: "#fff3e0"
  style.stroke: "#ef6c00"
}

# Experience Phase (Stripe + Microsoft)
uxd: {
  label: UXD + DX + A11y\n(Stripe + Microsoft)
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
}

# Technical Phase (Google)
trd: {
  label: Design Doc + Tradeoffs\n(Google)
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
}

tpd: {
  label: Test Plan + Experiments\n(Google + Spotify)
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
}

# Flow
discovery -> opportunity-spec
opportunity-spec -> press: synthesize
press -> faq: synthesize
opportunity-spec -> faq

vision -> press

faq -> prd: synthesize
press -> prd
opportunity-spec -> prd
requirements -> prd

experience -> uxd

uxd -> trd
prd -> trd: synthesize
technical -> trd

prd -> tpd
trd -> tpd: synthesize

# Legend
legend: {
  label: Company Contributions
  near: bottom-center
  grid-columns: 5

  patton: {
    label: "Patton\nOpportunity"
    shape: rectangle
    style.fill: "#fff3e0"
    style.stroke: "#ef6c00"
  }

  amz: {
    label: "Amazon\nNarratives"
    shape: rectangle
    style.fill: "#fff8e1"
    style.stroke: "#f9a825"
  }

  goog: {
    label: "Google\nRigor"
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
  }

  stripe: {
    label: "Stripe\nAPI-First"
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
  }

  msft: {
    label: "Microsoft\nA11y"
    shape: rectangle
    style.fill: "#f3e5f5"
    style.stroke: "#7b1fa2"
  }
}
