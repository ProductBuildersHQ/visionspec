# Big Tech Essentials - Product Flow (MRD Start)
# Simplified: Amazon + Google + Stripe only
# Layout: ELK

direction: down

title: {
  label: Big Tech Essentials - Product Flow
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

subtitle: {
  label: (Amazon + Google + Stripe)
  near: top-center
  shape: text
  style.font-size: 14
  style.italic: true
}

# Discovery Phase (Amazon + Google)
mrd: {
  label: MRD + OKRs\n(Amazon + Google)
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
}

# Vision Phase (Amazon)
press: {
  label: Press Release\n(Amazon)
  shape: rectangle
  style.fill: "#fff8e1"
  style.stroke: "#f9a825"
}

faq: {
  label: FAQ + Dev FAQ\n(Amazon + Stripe)
  shape: rectangle
  style.fill: "#fff8e1"
  style.stroke: "#f9a825"
}

narrative: {
  label: 6-Pager\n(Amazon)
  shape: rectangle
  style.fill: "#fce4ec"
  style.stroke: "#c2185b"
}

# Requirements Phase (Google + Stripe)
prd: {
  label: PRD + API Contracts\n(Google + Stripe)
  shape: rectangle
  style.fill: "#fff3e0"
  style.stroke: "#ef6c00"
}

# Experience Phase (Stripe)
uxd: {
  label: UXD + DX\n(Stripe)
  shape: rectangle
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
}

# Technical Phase (Google)
trd: {
  label: Design Doc + Tradeoffs\n(Google)
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
}

tpd: {
  label: Test Plan\n(Google)
  shape: rectangle
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
}

# Flow
mrd -> press: synthesize
press -> faq: synthesize
mrd -> faq

faq -> prd: synthesize
press -> prd
mrd -> prd

uxd -> trd
prd -> trd: synthesize

prd -> tpd
trd -> tpd: synthesize

mrd -> narrative: synthesize
prd -> narrative
press -> narrative

# Legend
legend: {
  label: Company Contributions (Essentials)
  near: bottom-center
  grid-columns: 3

  amz: {
    label: "Amazon\nCustomer Obsession"
    shape: rectangle
    style.fill: "#fff8e1"
    style.stroke: "#f9a825"
  }

  goog: {
    label: "Google\nTradeoffs & OKRs"
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1565c0"
  }

  stripe: {
    label: "Stripe\nAPI-First & DX"
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#2e7d32"
  }
}
